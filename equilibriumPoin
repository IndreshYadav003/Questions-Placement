def equilibriumPoint(array):
    for i in range(len(array)):
        left_sum = 0
        right_sum = 0

        for j in range(i):
            left_sum += array[j]

        for k in range(i + 1, len(array)):
            right_sum += array[k]

        if left_sum == right_sum:
            return i + 1

    return -1

