def rob(nums):
  # Base cases for recursion
  if not nums:
      return 0
  if len(nums) == 1:
      return nums[0]

  # Option 1: Rob the current house (nums[0]) and then rob from nums[2:]
  # (skipping nums[1] as it's adjacent)
  op1 = nums[0] + rob(nums[2:])

  # Option 2: Skip the current house (nums[0]) and rob from nums[1:]
  op2 = rob(nums[1:])

  return max(op1, op2)

# House Robber
houses = [2,7,9,3,1]
print(rob(houses))#12
