# count frequency of each element in the array
array=[2,4,2,4,3,1,3,2,42,1,2,54,5,5,43,5,5,0,0,54]
def count_freq(array):
    freq={}
    for i in array:
        if i in freq:
            freq[i]+=1
        else:
            freq[i]=1
    return freq
print(count_freq(array))#{2: 4, 4: 2, 3: 2, 1: 2, 42: 1, 54: 2, 5: 4, 43: 1, 0: 2}

